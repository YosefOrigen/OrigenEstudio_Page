    variant="header_2"
  />

  <nav class="lab-subnav" aria-label="Secciones destacadas del laboratorio">
    <a href="#por-donde-empezar">Por dónde empezar</a>
    <a href="#assets">Assets</a>
    <a href="#musicas-sonidos">Músicas y sonidos</a>
    <a href="#cursos">Cursos</a>
  </nav>

  <div class="lab-page">
